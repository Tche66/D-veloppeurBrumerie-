# ============================================================
# BRUMERIE — Variables d'environnement
# ============================================================
# 1. Copier ce fichier : cp .env.example .env.local
# 2. Remplir avec vos vraies valeurs Firebase Console
# 3. Dans Vercel : Settings → Environment Variables → ajouter chacune
# ============================================================

# ── Firebase ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSy_VOTRE_CLE_API
VITE_FIREBASE_AUTH_DOMAIN=brumerie.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=brumerie
VITE_FIREBASE_STORAGE_BUCKET=brumerie.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ── Admin ──────────────────────────────────────────────────
# Email et mot de passe du compte admin Firebase Auth
# (Créer dans Firebase Console → Authentication → Users)
VITE_ADMIN_EMAIL=admin@brumerie.ci

# ── Site ───────────────────────────────────────────────────
VITE_WA_NUMBER=2250586867693
VITE_SITE_URL=https://www.brumerie.com
